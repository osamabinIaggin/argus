# ── Required ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# ── Google OAuth (optional — enables Google sign-in) ──────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
# Required for PWA installed mode (redirect flow instead of popup)
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Infrastructure — set automatically by docker-compose, override if needed ──
# REDIS_URL=redis://redis:6379/0
# OUTPUT_DIR=/app/output
# DATABASE_URL=sqlite:////app/data/vi.db

# ── PostgreSQL / Supabase ───────────────────────────────────────────────────────
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
# DB_SSL_CERT=/app/prod-ca-2021.crt   # path to Supabase SSL root cert inside container

# ── PowerSync — real-time local-first sync (optional) ─────────────────────────
# 1. Create a free account at https://powersync.com
# 2. Create a project → connect it to your Supabase Postgres database
# 3. Paste powersync.yaml (in this repo root) into Sync Rules → Edit
# 4. Dashboard → Edit Instance → copy PowerSync URL + JWT Secret below
# POWERSYNC_URL=https://your-instance.powersync.journeyapps.com
# POWERSYNC_JWT_SECRET=your-powersync-jwt-secret
# VITE_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# ── Mastra cross-video agent ───────────────────────────────────────────────────
# MASTRA_URL=http://mastra:3001   # set automatically by docker-compose
# GOOGLE_GENERATIVE_AI_API_KEY=same_as_GEMINI_API_KEY

# ── Pipeline tuning ────────────────────────────────────────────────────────────
# DEFAULT_FPS=5
# MAX_SYNC_DURATION_SECONDS=60
# MAX_UPLOAD_BYTES=524288000
